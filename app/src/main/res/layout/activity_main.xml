<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="48dp">

        <!-- 顶部栏 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="52dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="折叠计数"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"/>
                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_service_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 运行中"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="11dp"
                android:paddingEnd="11dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- 主卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:gravity="center">

            <!-- 脉冲 + 大数字 -->
            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp">

                <View android:id="@+id/pulse1"
                    android:layout_width="220dp" android:layout_height="220dp"
                    android:background="@drawable/bg_pulse"
                    android:alpha="0" android:layout_gravity="center"/>

                <View android:id="@+id/pulse2"
                    android:layout_width="220dp" android:layout_height="220dp"
                    android:background="@drawable/bg_pulse"
                    android:alpha="0" android:layout_gravity="center"/>

                <View android:id="@+id/pulse3"
                    android:layout_width="220dp" android:layout_height="220dp"
                    android:background="@drawable/bg_pulse"
                    android:alpha="0" android:layout_gravity="center"/>

                <View
                    android:layout_width="180dp" android:layout_height="180dp"
                    android:background="@drawable/bg_circle"
                    android:layout_gravity="center"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="92sp"
                        android:fontFamily="sans-serif-black"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.05"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="累计折叠"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"/>
                </LinearLayout>
            </FrameLayout>

            <!-- 状态 -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="等待折叠…"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="18dp"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/separator"
                android:layout_marginTop="28dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <!-- 三列数据 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_today"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_primary"
                        android:textSize="28sp" android:fontFamily="sans-serif-bold"
                        android:letterSpacing="-0.02"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="今日" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="@color/separator" android:layout_gravity="center"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_session"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_primary"
                        android:textSize="28sp" android:fontFamily="sans-serif-bold"
                        android:letterSpacing="-0.02"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="本次" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="@color/separator" android:layout_gravity="center"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_hinge_angle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--°" android:textColor="@color/text_primary"
                        android:textSize="28sp" android:fontFamily="sans-serif-bold"
                        android:letterSpacing="-0.02"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="铰链角度" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- 近7天卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="20dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="近 7 天" android:textColor="@color/text_primary"
                        android:textSize="15sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:id="@+id/tv_week_total"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                </RelativeLayout>
                <TextView android:id="@+id/tv_avg_label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary" android:textSize="11sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/chart_bars"
                android:layout_width="match_parent" android:layout_height="88dp"
                android:orientation="horizontal" android:weightSum="7" android:gravity="bottom"/>

            <LinearLayout android:id="@+id/chart_labels"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:weightSum="7"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView android:id="@+id/btn_reset_session"
                android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_marginEnd="5dp"
                android:background="@drawable/bg_btn_dark"
                android:text="重置本次" android:textColor="@color/text_primary"
                android:textSize="14sp" android:fontFamily="sans-serif-medium"
                android:gravity="center" android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/btn_clear_all"
                android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_marginStart="5dp"
                android:background="@drawable/bg_btn_red"
                android:text="清空所有" android:textColor="@color/red"
                android:textSize="14sp" android:fontFamily="sans-serif-medium"
                android:gravity="center" android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <TextView android:id="@+id/btn_stop"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_dark"
            android:text="停止后台服务"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" android:fontFamily="sans-serif-medium"
            android:gravity="center" android:clickable="true" android:focusable="true"/>

    </LinearLayout>
</ScrollView>
