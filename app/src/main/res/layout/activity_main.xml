<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="48dp">

        <!-- ── 顶部导航栏 ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="折叠计数器"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.03"/>
                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_service_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 运行中"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_chip_green"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- ── 主计数卡片 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="32dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:gravity="center">

            <!-- 脉冲圆 + 数字 -->
            <FrameLayout
                android:layout_width="240dp"
                android:layout_height="240dp">

                <View android:id="@+id/pulse1"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_pulse"
                    android:alpha="0"
                    android:layout_gravity="center"/>

                <View android:id="@+id/pulse2"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_pulse"
                    android:alpha="0"
                    android:layout_gravity="center"/>

                <View android:id="@+id/pulse3"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_pulse"
                    android:alpha="0"
                    android:layout_gravity="center"/>

                <!-- 主圆背景 -->
                <View
                    android:layout_width="190dp"
                    android:layout_height="190dp"
                    android:background="@drawable/bg_circle_ring"
                    android:layout_gravity="center"/>

                <!-- 内容 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="88sp"
                        android:fontFamily="sans-serif-black"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.05"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="累计折叠次数"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
            </FrameLayout>

            <!-- 状态行 -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="等待折叠…"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="16dp"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/separator"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"/>

            <!-- 三列小数据 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_today"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_primary"
                        android:textSize="26sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="今日" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginTop="3dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="36dp"
                    android:background="@color/separator"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_session"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_primary"
                        android:textSize="26sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="本次" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginTop="3dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="36dp"
                    android:background="@color/separator"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_hinge_angle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—°" android:textColor="@color/text_primary"
                        android:textSize="26sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="铰链角度" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── 近7天图表卡片 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="近 7 天统计"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"/>
                <TextView android:id="@+id/tv_week_total"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <!-- 柱状图 -->
            <LinearLayout android:id="@+id/chart_bars"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:weightSum="7"
                android:gravity="bottom"/>

            <!-- 日期标签 -->
            <LinearLayout android:id="@+id/chart_labels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="7"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ── 操作区 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView android:id="@+id/btn_reset_session"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_btn_neutral"
                android:text="重置本次"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:clickable="true" android:focusable="true"/>

            <TextView android:id="@+id/btn_clear_all"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_btn_danger"
                android:text="清空所有数据"
                android:textColor="@color/red"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <TextView android:id="@+id/btn_stop"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_neutral"
            android:text="停止后台服务"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:clickable="true" android:focusable="true"/>

    </LinearLayout>
</ScrollView>
